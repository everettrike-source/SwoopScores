{
  "manifest_version": 3,
  "name": "SwoopScores",
  "version": "1.0.0",
  "description": "Displays RateMyProfessor scores inline on the University of Utah class schedule website.",

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["*://class-schedule.app.utah.edu/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": ["storage"],

  "host_permissions": [
    "*://class-schedule.app.utah.edu/*",
    "*://www.ratemyprofessors.com/*"
  ],

  "action": {
    "default_title": "SwoopScores"
  }
}
